# Public API base URL (browser). No trailing slash.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3006

# Optional: Socket.IO server URL (defaults to NEXT_PUBLIC_API_BASE_URL).
# NEXT_PUBLIC_SESSION_SOCKET_URL=http://localhost:3006

# Optional: Socket.IO path (defaults to /socket.io).
# NEXT_PUBLIC_SOCKET_IO_PATH=/socket.io

# Optional: log every Socket.IO event to the console (session socket only).
# NEXT_PUBLIC_SOCKET_IO_DEBUG=true
